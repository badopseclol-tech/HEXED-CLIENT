-- SAFE SPARKLES (NO STACKING / NO OVERSPAWN)

local MAX_SPARKLES = 200
local sparkles = {}

local function createSparkle()
	if #sparkles >= MAX_SPARKLES then
		return
	end

	local dot = Instance.new("Frame")
	dot.Size = UDim2.new(0, 3, 0, 3)
	dot.BackgroundColor3 = Color3.fromRGB(180, 80, 255)
	dot.BorderSizePixel = 0
	dot.Parent = main

	dot.Position = UDim2.new(math.random(), 0, math.random(), 0)

	table.insert(sparkles, dot)

	task.spawn(function()
		while dot.Parent do
			TweenService:Create(dot, TweenInfo.new(1.5), {
				Position = UDim2.new(math.random(), 0, math.random(), 0),
				BackgroundTransparency = math.random(3, 7) / 10
			}):Play()

			task.wait(1.5)
		end

		-- cleanup when removed
		for i, v in ipairs(sparkles) do
			if v == dot then
				table.remove(sparkles, i)
				break
			end
		end
	end)
end

task.spawn(function()
	while task.wait(2) do
		createSparkle()
	end
end)

