local unlocked = false

local function formatTime(seconds)
	if seconds == math.huge then
		return "Permanent Key"
	end

	local diff = seconds - os.time()
	if diff <= 0 then
		return "Expired"
	end

	local days = math.floor(diff / 86400)
	local hours = math.floor((diff % 86400) / 3600)

	return "Expires in " .. days .. "d " .. hours .. "h"
end

local function startCountdown(label, expiry)
	task.spawn(function()
		while gate.Parent and expiry ~= math.huge do
			local diff = expiry - os.time()

			if diff <= 0 then
				label.Text = "Expired"
				break
			end

			local days = math.floor(diff / 86400)
			local hours = math.floor((diff % 86400) / 3600)
			local mins = math.floor((diff % 3600) / 60)

			label.Text = string.format("Expires in %dd %dh %dm", days, hours, mins)

			task.wait(1)
		end

		if expiry == math.huge then
			label.Text = "Permanent Key"
		end
	end)
end

btn.MouseButton1Click:Connect(function()
	local key = box.Text
	local data = allowedKeys[key]

	if not data then
		box.Text = ""
		box.PlaceholderText = "Invalid Key"
		return
	end

	local hwid = getHWID()

	-- check expiry
	if data.expires ~= math.huge and os.time() > data.expires then
		box.Text = ""
		box.PlaceholderText = "Key Expired"
		return
	end

	-- bind HWID first time
	if data.hwid == nil then
		data.hwid = hwid
	end

	-- HWID mismatch check
	if data.hwid ~= hwid then
		box.Text = ""
		box.PlaceholderText = "HWID Locked"
		return
	end

	unlocked = true
	gate:Destroy()
end)

